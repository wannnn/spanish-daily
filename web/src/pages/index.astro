---
// Homepage — page 1 of the lesson archive at the Pages root (`/`).
import Base from '../layouts/Base.astro';
import Archive from '../components/Archive.astro';
import { loadArchive, pageCount, PAGE_SIZE } from '../lib/lessons';

const { newestFirst } = await loadArchive();
const total = pageCount(newestFirst.length);
const entries = newestFirst.slice(0, PAGE_SIZE);
---

<Base title="所有課程">
  <Archive entries={entries} current={1} total={total} />
</Base>
