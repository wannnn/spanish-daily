---
// Provisional root stub — NOT the homepage. The real homepage and the archive
// are later slices. This exists only so the site root resolves under the Pages
// base and gives a single link to reach the sample lesson during verification.
import Base from '../layouts/Base.astro';
import { loadLessons } from '../lib/lessons';

const lessons = await loadLessons();
const sample = lessons[0];
const base = import.meta.env.BASE_URL;
---

<Base title="Spanish Daily">
  <h1>Spanish Daily</h1>
  <p style="color: var(--muted);">
    Provisional placeholder. The homepage, the lesson archive, and search are
    later slices.
  </p>
  {
    sample && (
      <p>
        <a href={`${base}lessons/${sample.slug}/`}>
          Sample lesson: {sample.metadata.word} ({sample.slug})
        </a>
      </p>
    )
  }
</Base>
