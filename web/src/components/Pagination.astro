---
// Static pagination footer (docs/web-design.md): previous / page info / next, as
// plain links to static routes. No client-side state. Page 1 is `/`; later pages
// are `/page/N/`.
interface Props {
  current: number;
  total: number;
}
const { current, total } = Astro.props;
const base = import.meta.env.BASE_URL;

const href = (page: number) => (page <= 1 ? base : `${base}page/${page}/`);
const prev = current > 1 ? href(current - 1) : null;
const next = current < total ? href(current + 1) : null;
---

<nav class="pagination" aria-label="分頁">
  {prev ? <a href={prev} rel="prev">← 上一頁</a> : <span class="disabled">← 上一頁</span>}
  <span class="page-info">第 {current} / {total} 頁</span>
  {next ? <a href={next} rel="next">下一頁 →</a> : <span class="disabled">下一頁 →</span>}
</nav>
