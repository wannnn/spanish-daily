---
// Minimal mobile-first shell. Not the final visual design — deferred to a later
// slice. It exists to carry the manifest, viewport, and a readable column so the
// lesson content and the base-path/install wiring can be verified.
interface Props {
  title: string;
}
const { title } = Astro.props;

// The single source for the Pages base is Astro's `base`; read it here rather
// than hardcoding the repository name. `BASE_URL` is `/spanish-daily/`.
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Spanish Daily</title>
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="icon" href={`${base}icon.svg`} type="image/svg+xml" />
    <meta name="theme-color" content="#1f2933" />
    <style>
      :root {
        color-scheme: light dark;
        --fg: #1f2933;
        --muted: #6b7280;
        --line: #d1d5db;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, "Noto Sans TC", sans-serif;
        line-height: 1.7;
        color: var(--fg);
      }
      main {
        max-width: 42rem;
        margin: 0 auto;
        padding: 1.25rem 1rem 4rem;
      }
      h1 {
        line-height: 1.25;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 0.75rem 0;
        display: block;
        overflow-x: auto;
      }
      th,
      td {
        border: 1px solid var(--line);
        padding: 0.35rem 0.6rem;
        text-align: left;
      }
      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #e5e7eb;
          --muted: #9ca3af;
          --line: #374151;
        }
        body {
          background: #111827;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
