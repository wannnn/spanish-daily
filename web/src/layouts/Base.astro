---
// Mobile-first shell and the site's global styling, following docs/web-design.md:
// single-column reading, a limited desktop width, warm earth-tone tokens, accent
// colours only on section headings, links, and table headers. Styles are global
// so they also reach the lesson body injected via `set:html`.
interface Props {
  title: string;
}
const { title } = Astro.props;

// The single source for the Pages base is Astro's `base`; never hardcode the repo
// name. `BASE_URL` is `/spanish-daily/`.
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Spanish Daily</title>
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="icon" href={`${base}icon-192.png`} type="image/png" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <meta name="theme-color" content="#f7f3ea" />
    <style is:global>
      :root {
        color-scheme: light;
        --background: #f7f3ea;
        --surface: #fffdf8;
        --card: #fbf6ec;
        --text: #342f29;
        --muted: #756d62;
        --primary: #4f6650;
        --accent: #a66f4f;
        --border: #ded5c7;
        --table-header: #e4eadf;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--background);
        color: var(--text);
        font-family: system-ui, -apple-system, "Noto Sans TC", "PingFang TC", sans-serif;
        line-height: 1.7;
      }

      main {
        max-width: 44rem;
        margin: 0 auto;
        padding: 1.25rem 1rem 4rem;
      }

      a {
        color: var(--accent);
      }

      /* Site header — identical across homepage pages. */
      .site-title {
        margin: 0.25rem 0 0.25rem;
        font-size: 1.9rem;
        line-height: 1.2;
        color: var(--text);
      }
      .site-subtitle {
        margin: 0 0 1.5rem;
        color: var(--muted);
      }

      /* Homepage lesson list — lightweight cards, one clickable card per lesson. */
      .lessons {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }
      .lessons a {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        padding: 0.85rem 1rem;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        box-shadow: 0 1px 2px rgba(52, 47, 41, 0.05), 0 2px 6px rgba(52, 47, 41, 0.05);
        text-decoration: none;
        color: var(--text);
      }
      .lessons a:hover {
        border-color: var(--primary);
        box-shadow: 0 2px 5px rgba(52, 47, 41, 0.08), 0 4px 10px rgba(52, 47, 41, 0.06);
      }
      .lessons a:hover .lesson-word {
        text-decoration: underline;
      }
      .lesson-n {
        color: var(--muted);
        font-size: 0.85rem;
        font-variant-numeric: tabular-nums;
      }
      .lesson-word {
        color: var(--primary);
        font-weight: 600;
        font-size: 1.15rem;
      }
      .lesson-sub {
        margin-left: auto;
        color: var(--muted);
        font-size: 0.9rem;
        white-space: nowrap;
      }

      /* Pagination and lesson-page nav — static links, no client state. */
      .pagination,
      .lesson-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
      }
      /* Homepage pagination: separated by spacing, no divider line. */
      .pagination {
        margin-top: 2rem;
      }
      /* Lesson-page nav keeps its divider (lesson page unchanged). */
      .lesson-nav {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
      }
      .pagination .page-info {
        color: var(--muted);
        font-size: 0.9rem;
        font-variant-numeric: tabular-nums;
      }
      .disabled {
        color: var(--border);
      }

      /* Lesson page. */
      .backlink {
        margin: 0 0 1rem;
        font-size: 0.95rem;
      }
      .lesson-head {
        margin: 0 0 1.5rem;
      }
      .lesson-title {
        margin: 0 0 0.25rem;
        font-size: 2rem;
      }
      .lesson-meta {
        margin: 0;
        color: var(--muted);
      }
      .lesson-body h2 {
        margin-top: 2rem;
        padding-bottom: 0.3rem;
        border-bottom: 1px solid var(--border);
        color: var(--primary);
        font-size: 1.3rem;
      }

      /* Tables — full content width, low-chroma header, scroll when too wide. */
      .table-scroll {
        overflow-x: auto;
        margin: 0.85rem 0;
      }
      .table-scroll table {
        width: 100%;
        border-collapse: collapse;
      }
      .table-scroll th,
      .table-scroll td {
        border: 1px solid var(--border);
        padding: 0.4rem 0.65rem;
        text-align: left;
        background: var(--surface);
      }
      .table-scroll th {
        background: var(--table-header);
        font-weight: 600;
        white-space: nowrap;
      }
      /* Conjugation value column, slightly emphasised. */
      .table-scroll td:last-child {
        font-weight: 500;
      }

      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
